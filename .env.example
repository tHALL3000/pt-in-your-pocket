# ─── Supabase ────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-[REGION].pooler.supabase.com:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Web Push (daily reminders) ──────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:you@example.com

# ─── Resend (email progress report to PT) ────────────────────────────────────
# Sign up at https://resend.com — free tier is sufficient
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Cron secret (GitHub Actions daily reminder job) ─────────────────────────
# Any random string — set the same value in your GitHub Actions secrets
CRON_SECRET=your-random-secret-here

# ─── Demo mode ───────────────────────────────────────────────────────────────
# Set to true to run the app without a database (uses localStorage)
# Perfect for trying the app or hosting a public demo
NEXT_PUBLIC_DEMO_MODE=false
